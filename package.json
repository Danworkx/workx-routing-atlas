{
  "name": "workx-routing-atlas",
  "version": "1.0.0",
  "description": "Static crawler that maps every route, link, redirect and role guard across workx-app and workx-lms",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "crawl": "ts-node src/index.ts",
    "crawl:fast": "ts-node --transpile-only src/index.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "glob": "^9.3.5"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
